# =============================================================================
#  JIVANI GEMS — Environment variables
# =============================================================================
#  HOW THIS WORKS:
#   • The PUBLIC keys below (SUPABASE_URL, SUPABASE_ANON_KEY, RAZORPAY_KEY_ID)
#     are safe to expose in the browser. You ALSO paste them into js/config.js so the
#     static front-end can read them. They are protected by Supabase Row Level
#     Security + Razorpay's server-side signature verification.
#   • The SECRET keys (RAZORPAY_KEY_SECRET, RAZORPAY_WEBHOOK_SECRET, RESEND_API_KEY,
#     SUPABASE_SERVICE_ROLE_KEY) are NEVER put in front-end code. They are read ONLY
#     by the Netlify serverless functions in netlify/functions/. You set them in the
#     Netlify dashboard (Site settings → Environment variables) for production, and in
#     this .env file for local `netlify dev` testing.
#
#  1. Copy this file to ".env"          ->  cp .env.example .env   (or copy in Explorer)
#  2. Fill in real values
#  3. NEVER commit .env (it is git-ignored)
# =============================================================================

# ---- Supabase (Project → Settings → API) ----
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SECRET. Used by serverless functions to write orders/vouchers.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- Razorpay (Dashboard → Settings → API Keys) ----
# Key ID is public (also goes in js/config.js). Key Secret is SECRET — here only.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret — the value you set when creating the webhook (Step 3 of guide)
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ---- Resend email (https://resend.com → API Keys) ----
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# The "from" address must be on a domain you've verified in Resend.
ORDER_FROM_EMAIL=Jivani Gems <orders@your-verified-domain.com>

# ---- Site ----
# Used in emails + the Razorpay checkout context. No trailing slash.
SITE_URL=http://localhost:8888
